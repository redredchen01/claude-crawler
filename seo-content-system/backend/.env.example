# Server
PORT=8000
NODE_ENV=development

# Database
DATABASE_URL=seo-content.db

# Features
ENABLE_SERP_ANALYSIS=true
ENABLE_CLUSTERING=false

# Rate Limiting (Phase 2)
RATE_LIMIT_JOBS_PER_HOUR=100
RATE_LIMIT_EXPANSION_PER_JOB=10000

# LLM Content Generation (Phase 5)
ANTHROPIC_API_KEY=sk-ant-api03-xxxxx
LLM_MODEL=claude-3-5-sonnet-20241022
LLM_MAX_TOKENS=4096
LLM_ENABLED=true

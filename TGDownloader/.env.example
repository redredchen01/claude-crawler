# Database Configuration
DATABASE_URL=postgres://postgres:postgres@localhost:5432/tgdownloader?sslmode=disable

# Redis Configuration
REDIS_URL=redis://localhost:6379

# Server Configuration
LISTEN_ADDR=:8080
LOG_LEVEL=info

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Telegram API (for local Bot API Server)
TELEGRAM_API_ID=your_api_id_here
TELEGRAM_API_HASH=your_api_hash_here

# Bot API Mode: "cloud" (default) or "local"
# - cloud: Use official Telegram Bot API (limits: 50MB per file)
# - local: Use local Telegram Bot API Server (supports up to 2GB)
BOT_API_MODE=cloud

# Local Bot API Server URL (used when BOT_API_MODE=local)
BOT_API_LOCAL_URL=http://localhost:8081

# FFmpeg Configuration
MAX_FFMPEG_PROCS=2

# Archive-on-File Configuration
AOF_ENABLED=true

# S3 Configuration (for large files fallback)
S3_ENDPOINT=
S3_REGION=us-east-1
S3_BUCKET=tgdownloader

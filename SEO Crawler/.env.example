# ============== API Configuration ==============
API_PORT=3001
NODE_ENV=development

# ============== Database Configuration ==============
# PostgreSQL connection string
DATABASE_URL=postgresql://seo_crawler:password@localhost:5432/seo_crawler

# Connection pool settings
DB_POOL_MAX=10
DB_IDLE_TIMEOUT=30000
DB_CONNECTION_TIMEOUT=2000

# ============== Authentication ==============
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d
API_KEY_PREFIX=sk_

# ============== Claude API (Phase 9.3) ==============
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_API_VERSION=2024-01-15

# ============== Webhooks ==============
WEBHOOK_TIMEOUT_MS=5000
WEBHOOK_MAX_RETRIES=3
WEBHOOK_RETRY_BACKOFF_BASE=1000

# ============== Logging ==============
LOG_LEVEL=debug
LOG_FORMAT=json

# ============== Monitoring (Phase 9.4) ==============
PROMETHEUS_PORT=9090
SENTRY_DSN=https://...@sentry.io/...

# ============== Admin User ==============
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@seo-crawler.local
ADMIN_PASSWORD=change-me-in-production

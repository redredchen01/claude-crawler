# YD 2026 Workspace - Environment Secrets Template
# 複製此文件為 .env 並填寫實際值（.env 已被 .gitignore 忽略）

# --- Global / Core ---
YD_WORKSPACE="/Users/dex/YD 2026"
YD_MEMORY="$HOME/.claude/memory"

# --- Skill: Linear Slack Reporter ---
LINEAR_API_KEY="lin_api_..."
SLACK_WEBHOOK_URL="https://hooks.slack.com/services/..."

# --- Project: TG Bot (claude_code_telegram_bot) ---
TELEGRAM_BOT_TOKEN="..."
CLAUDE_API_KEY="sk-ant-..."

# --- Project: VWRS (video-watermark-removal-system) ---
# 需要 FFmpeg 和 OpenCV 路徑（如有特殊位置）
# VIDEO_PROCESSOR_PATH="/usr/local/bin/ffmpeg"

# --- Project: Daily Report (Sheets) ---
GOOGLE_SHEETS_ID="..."
GOOGLE_SERVICE_ACCOUNT_JSON="path/to/service-account.json"

# --- Agent System ---
# 用於 agent-tasks.sh 的默認 Agent ID
DEFAULT_AGENT_ID="gemini-cli-v2026"
